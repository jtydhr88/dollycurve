{
  "name": "dollycurve",
  "version": "0.2.0",
  "description": "Blender-style F-Curve / camera path editor for Three.js — bezier handles, easings, cycles modifier, canvas graph editor + timeline. Web port of Blender's animation engine.",
  "type": "module",
  "license": "MIT",
  "author": "Terry Jia",
  "homepage": "https://jtydhr88.github.io/dollycurve",
  "repository": {
    "type": "git",
    "url": "https://github.com/jtydhr88/dollycurve"
  },
  "bugs": {
    "url": "https://github.com/jtydhr88/dollycurve/issues"
  },
  "keywords": [
    "blender",
    "fcurve",
    "keyframe",
    "animation",
    "bezier",
    "easing",
    "camera",
    "three.js",
    "cinematic",
    "graph-editor",
    "timeline",
    "interpolation"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib",
    "build:lib": "vite build --mode lib",
    "build:playground": "vite build",
    "build:all": "vite build --mode lib && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/three": "^0.183.0",
    "jsdom": "^25.0.0",
    "three": "^0.183.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.0"
  }
}
